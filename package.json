{
  "name": "enterprise-bun-mono",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@moonrepo/cli": "^2.3.4",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "dependency-cruiser": "^17.4.3",
    "knip": "^6.20.0",
    "lefthook": "^2.1.9",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@latest",
  "private": true,
  "scripts": {
    "arch": "bunx depcruise . --config .dependency-cruiser.cjs",
    "build": "moon run :build",
    "check": "bunx biome check .",
    "check:write": "bunx biome check --write .",
    "create": "bun run tooling/create-project/src/index.ts",
    "deadcode": "bunx knip",
    "deps:check": "bunx syncpack lint && bunx syncpack format --check",
    "deps:fix": "bunx syncpack fix && bunx syncpack format",
    "dev": "moon run :dev",
    "format": "moon run :format",
    "lint": "moon run :lint",
    "sbom": "syft . -o cyclonedx-json=sbom.cdx.json",
    "security:fs": "trivy fs .",
    "security:secrets": "gitleaks detect --source . --verbose",
    "test": "moon run :test",
    "typecheck": "moon run :typecheck",
    "verify": "bun run check && bun run deps:check && bun run deadcode && bun run arch && moon run :typecheck :test :build"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "tooling/*"
  ]
}
