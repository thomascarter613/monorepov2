{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "apps/*": {
      "project": ["src/**/*.ts"]
    },
    "services/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreBinaries": ["gitleaks", "trivy", "syft"]
}
